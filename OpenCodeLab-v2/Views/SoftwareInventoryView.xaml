<UserControl x:Class="OpenCodeLab.Views.SoftwareInventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12">
            <Button Content="Scan All" Command="{Binding ScanAllCommand}" Style="{StaticResource UniformButton}" Margin="0,0,8,0" />
            <Button Content="Scan Selected" Command="{Binding ScanSelectedCommand}" Style="{StaticResource UniformButton}" Margin="0,0,8,0" />
            <Button Content="Cancel" Command="{Binding CancelScanCommand}" Style="{StaticResource RedButton}" Margin="0,0,8,0" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0" />
            <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource UniformButton}" Margin="8,0,8,0" />
            <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" Style="{StaticResource UniformButton}" Margin="0,0,8,0" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0" />
            <Button Content="Clear" Command="{Binding ClearCommand}" Style="{StaticResource RedButton}" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Filter Row -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Foreground="{StaticResource TextBrush}" Background="{StaticResource CardBrush}" Padding="8" 
                         ToolTip="Search by software name, version, or publisher" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableVMs}" SelectedItem="{Binding SelectedVM}" 
                          DisplayMemberPath="Name" Foreground="{StaticResource TextBrush}" Background="{StaticResource CardBrush}" Padding="8" Margin="12,0,0,0" />
                <CheckBox Grid.Column="2" Content="Grouped View" IsChecked="{Binding IsGroupedView}" 
                          Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="100" Height="4" 
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" 
                             Foreground="{StaticResource PrimaryBrush}" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="3">
            <!-- Grouped View -->
            <ScrollViewer Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVis}}" 
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding FilteredResults}" Margin="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" 
                                    BorderThickness="1" CornerRadius="4" Margin="0,0,0,12" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <!-- VM Header -->
                                    <!-- VM Header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding VMName}" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextBrush}" FontSize="14" />
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x2705; Scanned" />
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Success}" Value="False">
                                                            <Setter Property="Text" Value="{Binding ErrorMessage, StringFormat=&#x274C; {0}}" />
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding ScannedAt, StringFormat=Scanned: {0:g}}" 
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                    </Grid>
                                    <!-- Software List -->
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Software}" Background="Transparent" 
                                             BorderThickness="0" Padding="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource TextBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Version}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Publisher}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" />
                                                        <TextBlock Grid.Column="3" Text="{Binding InstallDate, StringFormat='d'}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Flat Table View -->
            <DataGrid Grid.Row="0" ItemsSource="{Binding FilteredFlatList}" 
                      Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}"
                      AutoGenerateColumns="False" VirtualizingPanel.IsVirtualizing="True" 
                      Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                      BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Margin="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="VM Name" Binding="{Binding VMName}" Width="150" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
                    <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="150" />
                    <DataGridTextColumn Header="Install Date" Binding="{Binding InstallDate, StringFormat='d'}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State -->
            <TextBlock Grid.Row="0" Text="No scan results. Click 'Scan All' to inventory running VMs." 
                       Foreground="{StaticResource TextSecondaryBrush}" 
                       Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
        </Grid>
    </Grid>
</UserControl>
